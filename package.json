{
	"name": "@ctx-core/fontawesome-ui-svelte",
	"version": "1.1.260",
	"description": "ctx-core fontawesome",
	"keywords": [
		"ctx-core",
		"fontawesome"
	],
	"homepage": "https://github.com/ctx-core/fontawesome-ui-svelte#readme",
	"bugs": {
		"url": "https://github.com/ctx-core/fontawesome-ui-svelte/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/fontawesome-ui-svelte.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-fontawesome-ui-svelte@briantakita.me"
	},
	"bin": {
		"refresh-font-awesome": "./bin/refresh-font-awesome.mjs"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "bun run clean && bun run build && bun run test && publint && attw --pack --ignore-rules cjs-resolves-to-esm",
		"test": "bun run test:types && bun run test:unit",
		"test:types": "tsc --noEmit",
		"test:unit": "uvu . '\\.test\\.(ts|tsx|js|jsx)$'",
		"disable:test:unit:coverage": "c8 bun run test:unit"
	},
	"type": "module",
	"files": [
		"*.d.ts",
		"*.js",
		"*.json",
		"./bin",
		"./ui"
	],
	"types": "./index.d.ts",
	"exports": {
		".": "./index.js",
		"./package.json": "./package.json"
	},
	"dependencies": {
		"@ctx-core/svg": "*",
		"@ctx-core/svg-ui-svelte": "*",
		"ctx-core": "*",
		"dom-serializer": "^2.0.0",
		"domutils": "^3.2.2",
		"htmlparser2": "^10.1.0",
		"import-meta-resolve": "^4.2.0",
		"svelte": "^5.53.7",
		"tiny-glob": "^0.2.9"
	},
	"devDependencies": {
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false
}
